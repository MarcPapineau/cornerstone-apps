# peptide-resource-app — environment template
# Copy to .env.local for local dev (and set the same vars in Netlify UI for prod).
# Never commit .env / .env.local — only this template (.env.example).

# --- Anthropic ---------------------------------------------------------------
# Used by netlify/functions/vitalis-chat-background.js to call the Claude API.
# Never expose to the browser. Only the background function reads this var.
ANTHROPIC_API_KEY=

# --- Internal function auth (Bug #1 fix, 2026-05-01) -------------------------
# Shared secret used to HMAC-sign internal dispatches from vitalis-chat.js
# (sync router) → vitalis-chat-background.js (Anthropic-calling worker).
# Without this set, the sync router refuses to dispatch and the background
# function refuses every incoming request — fail closed.
#
# Generate with: openssl rand -hex 32
INTERNAL_FN_SECRET=

# --- Netlify Blobs (only needed if running outside the Netlify build env) ---
# In production these are auto-injected by Netlify's runtime context.
# For local dev with `netlify dev`, also auto-injected. Set manually only
# when running on a non-Netlify host (e.g., bare `node` smoke tests).
NETLIFY_SITE_ID=
NETLIFY_TOKEN=
