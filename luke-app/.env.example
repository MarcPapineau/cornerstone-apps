# ============================================================
# Vitalis POS — Environment Variables
# Copy to .env for local dev; set as Railway env vars in production.
# NEVER commit .env or any file with real values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── REQUIRED SECRETS (Railway: set in Variables tab) ────────

# LUKE_BEARER — bearer token for the OpenClaw / Luke AI inference server.
# Obtain from: provider admin (OpenClaw dashboard or your self-hosted server).
# Rotation: Levite (Vault Keeper) agent via Doppler.
LUKE_BEARER=your_luke_bearer_token_here

# WINDMILL_TOKEN — API token for Windmill workflow engine (mybioyouth_order_v1).
# Obtain from: Windmill admin panel → Settings → API tokens.
# Rotation: Levite (Vault Keeper) agent via Doppler.
WINDMILL_TOKEN=your_windmill_token_here

# RESEND_KEY — API key for Resend transactional email (client package emails).
# Obtain from: https://resend.com/api-keys
# Rotation: Levite (Vault Keeper) agent via Doppler.
RESEND_KEY=re_your_resend_api_key_here

# ── OPTIONAL / DEV DEFAULTS ──────────────────────────────────

# Luke AI inference endpoint (defaults to localhost if unset)
LUKE_URL=http://127.0.0.1:18789/v1/chat/completions

# Luke AI model name (defaults to "openclaw" if unset)
LUKE_MODEL=openclaw

# Windmill base URL (defaults to localhost in dev, set for Railway)
WINDMILL_BASE_URL=https://your-windmill-instance.example.com

# ── Health-check / CI only (not needed for app runtime) ─────
N8N_API_KEY=
ANTHROPIC_API_KEY=
LUMA_API_KEY=
GHL_PIT=
